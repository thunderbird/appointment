# Keep the build context clean and reproducible: the image installs deps from
# package-lock.json via `npm ci`, so host-installed node_modules/dist must NOT be
# copied in (they bloat the image, can carry cross-arch native binaries, and can
# desync npm ci). See frontend/deploy.dockerfile.
node_modules
dist
.git
*.log
coverage
.env
.env.*
!.env.*.example
